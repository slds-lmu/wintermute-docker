# ~/.zsh_aliases — sourced by ~/.zshrc.
# Aliases + small helper functions. Ported from sysadmin/stow/shell/.zsh_aliases,
# trimmed to what's relevant inside the slds-tools yolobox image.

# ---- basic ls / fs ----
alias ll='ls -lh'
alias la='ls -lha'
alias du='du -h'
alias df='df -h'
alias mkdir='mkdir -p'           # interactive only; scripts ignore aliases

# ---- colors ----
alias ls='ls --color=auto'
alias grep='grep --color=auto'

# ---- R ----
# Cleaner startup: no save/restore prompts, no version banner.
alias R='R --no-save --no-restore-data --quiet'

# ---- git ----
# Short verbs live in ~/.gitconfig under [alias] so they work in any shell.
alias g='git'

# ---- count-files ----
# Per top-level entry in cwd, print path + count of all filesystem entries
# (files + dirs) beneath it. First line is grand total for cwd. No args.
count-files() {
  find . -maxdepth 1 -type d -exec sh -c 'echo "{}"; find "{}" | wc -l' \;
}
